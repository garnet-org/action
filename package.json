{
  "name": "garnetai-action",
  "version": "1.0.0",
  "description": "GarnetAI GitHub Action",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garnet-org/action.git"
  },
  "bugs": {
    "url": "https://github.com/garnet-org/action/issues"
  },
  "keywords": [
    "actions"
  ],
  "exports": {
    ".": "./dist/main/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "ncc build src/main.js -o dist/main --license licenses.txt && ncc build src/post.js -o dist/post --license licenses.txt && sed -i \"s/\\r$//\" dist/main/index.js dist/post/index.js"
  },
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "tar": "^7.5.11"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4"
  }
}